<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AMICA CX KPI Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            padding: 20px;
            min-height: 100vh;
        }

        .dashboard-container {
            max-width: 1800px;
            margin: 0 auto;
        }

        .dashboard-header {
            background: white;
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .dashboard-header h1 {
            color: #1a3a52;
            font-size: 32px;
            font-weight: 700;
        }

        .header-controls {
            display: flex;
            gap: 15px;
            align-items: center;
            flex-wrap: wrap;
        }

        .dashboard-header .date-range {
            color: #666;
            font-size: 14px;
        }

        .csv-status {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 15px;
            background: #e8f5e9;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            color: #2e7d32;
        }

        .csv-status.loading {
            background: #fff3e0;
            color: #e65100;
        }

        .csv-status.error {
            background: #ffebee;
            color: #c62828;
        }

        .status-indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #2e7d32;
            display: inline-block;
        }

        .csv-status.loading .status-indicator {
            background: #e65100;
            animation: pulse 1.5s infinite;
        }

        .csv-status.error .status-indicator {
            background: #c62828;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .csv-upload {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .csv-upload input[type="file"] {
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
        }

        .csv-upload button {
            padding: 10px 20px;
            background: #fdb913;
            color: #1a3a52;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            font-size: 13px;
        }

        .csv-upload button:hover {
            background: #ffca3f;
        }

        .section-filter {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 8px 16px;
            background: white;
            border: 2px solid #ddd;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            color: #666;
            transition: all 0.3s;
            font-size: 13px;
            position: relative;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-btn.active {
            background: #1a3a52;
            color: white;
            border-color: #1a3a52;
        }

        .filter-btn:hover {
            border-color: #1a3a52;
        }

        .negative-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #dc3545;
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 700;
            margin-left: 4px;
        }

        .filter-btn.active .negative-badge {
            background: rgba(255, 255, 255, 0.3);
            color: white;
        }

        .section {
            background: white;
            border-radius: 12px;
            margin-bottom: 30px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: none;
        }

        .section.active {
            display: block;
        }

        .section-header {
            background: linear-gradient(135deg, #1a3a52 0%, #2d5a7b 100%);
            color: white;
            padding: 20px 30px;
            font-size: 22px;
            font-weight: 600;
            border-bottom: 3px solid #fdb913;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            padding: 30px;
        }

        .kpi-card {
            background: white;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 25px;
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
            overflow: hidden;
        }

        .kpi-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.12);
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #fdb913, #ff6b6b);
        }

        .kpi-label {
            font-size: 13px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
            font-weight: 600;
        }

        .kpi-value {
            font-size: 36px;
            font-weight: 700;
            color: #1a3a52;
            margin-bottom: 15px;
            display: flex;
            align-items: baseline;
            gap: 12px;
        }

        .kpi-unit {
            font-size: 18px;
            color: #999;
            font-weight: 400;
        }

        .kpi-change {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
            font-size: 14px;
            font-weight: 600;
        }

        .change-value {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-weight: 700;
        }

        .change-positive {
            background-color: #d4edda;
            color: #155724;
        }

        .change-negative {
            background-color: #f8d7da;
            color: #721c24;
        }

        .change-neutral {
            background-color: #e2e3e5;
            color: #383d41;
        }

        .indicator {
            display: inline-block;
            font-size: 20px;
            width: 24px;
            text-align: center;
        }

        .indicator-up {
            color: #28a745;
        }

        .indicator-down {
            color: #dc3545;
        }

        .indicator-same {
            color: #ffc107;
        }

        .trend-container {
            position: relative;
            height: 60px;
            margin-top: 15px;
            background: #f9f9f9;
            border-radius: 4px;
            padding: 8px;
        }

        .trend-canvas {
            width: 100% !important;
            height: 60px !important;
        }

        .kpi-footer {
            font-size: 12px;
            color: #999;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #e0e0e0;
        }

        .legend {
            display: flex;
            gap: 30px;
            padding: 20px 30px;
            background: #f9f9f9;
            border-top: 1px solid #e0e0e0;
            flex-wrap: wrap;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #666;
        }

        .legend-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }

        .green { background-color: #28a745; }
        .red { background-color: #dc3545; }
        .yellow { background-color: #ffc107; }

        .error-message {
            background-color: #f8d7da;
            color: #721c24;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
            border-left: 4px solid #721c24;
        }

        .success-message {
            background-color: #d4edda;
            color: #155724;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
            border-left: 4px solid #155724;
        }

        .loading-placeholder {
            text-align: center;
            padding: 60px 30px;
            color: #999;
        }

        .loading-spinner {
            display: inline-block;
            width: 40px;
            height: 40px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #1a3a52;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @media (max-width: 1400px) {
            .kpi-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 1024px) {
            .kpi-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }
            
            .dashboard-header {
                flex-direction: column;
                gap: 15px;
            }

            .header-controls {
                flex-direction: column;
                width: 100%;
            }

            .csv-upload,
            .section-filter {
                width: 100%;
            }

            .filter-btn {
                flex: 1;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Error/Success Messages -->
        <div class="error-message" id="errorMessage"></div>
        <div class="success-message" id="successMessage"></div>

        <!-- Header -->
        <div class="dashboard-header">
            <div>
                <h1>AMICA CX KPI Dashboard</h1>
            </div>
            <div class="header-controls">
                <div class="csv-status loading" id="csvStatus">
                    <span class="status-indicator"></span>
                    <span id="csvStatusText">Loading KPI data...</span>
                </div>
                <div class="csv-upload" style="display: none;" id="manualUpload">
                    <input type="file" id="csvFile" accept=".csv" />
                    <button onclick="loadCSV()">Load CSV</button>
                </div>
                <div class="date-range">
                    <strong>Reporting Period:</strong> Last 24 Months<br>
                    <strong>Last Updated:</strong> <span id="lastUpdated">-</span>
                </div>
            </div>
        </div>

        <!-- Section Filters -->
        <div style="background: white; padding: 20px 30px; border-radius: 12px; margin-bottom: 30px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            <div style="font-size: 14px; font-weight: 600; color: #666; margin-bottom: 15px;">Filter by Section:</div>
            <div class="section-filter">
                <button class="filter-btn active" onclick="filterSection(event, 'all')">
                    <span>All Sections</span>
                    <span class="negative-badge" id="badge-all" style="display: none;"></span>
                </button>
                <button class="filter-btn" onclick="filterSection(event, 'Quote')">
                    <span>📋 Quote</span>
                    <span class="negative-badge" id="badge-Quote" style="display: none;"></span>
                </button>
                <button class="filter-btn" onclick="filterSection(event, 'Onboarding')">
                    <span>🚀 Onboarding</span>
                    <span class="negative-badge" id="badge-Onboarding" style="display: none;"></span>
                </button>
                <button class="filter-btn" onclick="filterSection(event, 'Billing')">
                    <span>💳 Billing</span>
                    <span class="negative-badge" id="badge-Billing" style="display: none;"></span>
                </button>
                <button class="filter-btn" onclick="filterSection(event, 'Services')">
                    <span>🔧 Services</span>
                    <span class="negative-badge" id="badge-Services" style="display: none;"></span>
                </button>
                <button class="filter-btn" onclick="filterSection(event, 'Claims')">
                    <span>📋 Claims</span>
                    <span class="negative-badge" id="badge-Claims" style="display: none;"></span>
                </button>
                <button class="filter-btn" onclick="filterSection(event, 'Transactional')">
                    <span>📊 Transactional</span>
                    <span class="negative-badge" id="badge-Transactional" style="display: none;"></span>
                </button>
            </div>
        </div>

        <!-- Dynamic Sections Container -->
        <div id="dashboardContent">
            <div class="loading-placeholder">
                <div class="loading-spinner"></div>
                <p>Loading KPI Dashboard...</p>
            </div>
        </div>

        <!-- Legend -->
        <div class="legend">
            <div class="legend-item">
                <div class="legend-dot green"></div>
                <span>Positive Trend (Increase)</span>
            </div>
            <div class="legend-item">
                <div class="legend-dot red"></div>
                <span>Negative Trend (Decrease)</span>
            </div>
            <div class="legend-item">
                <div class="legend-dot yellow"></div>
                <span>No Change</span>
            </div>
        </div>
    </div>

    <script>
        let kpiData = [];
        let chartInstances = {};
        let currentFilter = 'all';

        // Load CSV from local directory
        async function loadLocalCSV() {
            const statusEl = document.getElementById('csvStatus');
            const statusText = document.getElementById('csvStatusText');
            
            try {
                // Try to load from local directory
                const response = await fetch('kpi-data.csv');
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const text = await response.text();
                kpiData = parseCSV(text);
                
                if (kpiData.length === 0) {
                    throw new Error('CSV file is empty or invalid');
                }
                
                // Update status
                statusEl.className = 'csv-status';
                statusText.textContent = `✓ Loaded ${kpiData.length} KPIs`;
                document.getElementById('lastUpdated').textContent = new Date().toLocaleString();
                
                showSuccess(`Successfully loaded ${kpiData.length} KPIs from local directory`);
                updateNegativeIndicators();
                renderDashboard();
                filterSection(null, currentFilter);
                
            } catch (error) {
                console.error('Error loading CSV:', error);
                statusEl.className = 'csv-status error';
                statusText.textContent = '✗ Failed to load kpi-data.csv';
                document.getElementById('manualUpload').style.display = 'flex';
                showError(`Could not load CSV from local directory: ${error.message}. Please upload manually.`);
            }
        }

        // Load CSV file from manual upload
        async function loadCSV() {
            const fileInput = document.getElementById('csvFile');
            const file = fileInput.files[0];

            if (!file) {
                showError('Please select a CSV file');
                return;
            }

            try {
                const text = await file.text();
                kpiData = parseCSV(text);
                
                if (kpiData.length === 0) {
                    throw new Error('CSV file is empty or invalid');
                }
                
                const statusEl = document.getElementById('csvStatus');
                const statusText = document.getElementById('csvStatusText');
                statusEl.className = 'csv-status';
                statusText.textContent = `✓ Loaded ${kpiData.length} KPIs`;
                
                showSuccess(`Successfully loaded ${kpiData.length} KPIs`);
                document.getElementById('lastUpdated').textContent = new Date().toLocaleString();
                updateNegativeIndicators();
                renderDashboard();
                filterSection(null, currentFilter);
            } catch (error) {
                showError('Error reading CSV file: ' + error.message);
            }
        }

        // Parse CSV content
        function parseCSV(csvText) {
            const lines = csvText.trim().split('\n');
            if (lines.length < 2) return [];
            
            const headers = lines[0].split(',').map(h => h.trim());
            const data = [];

            for (let i = 1; i < lines.length; i++) {
                if (!lines[i].trim()) continue;
                
                const obj = {};
                const values = lines[i].split(',');

                for (let j = 0; j < headers.length; j++) {
                    obj[headers[j]] = (values[j] || '').trim();
                }

                if (obj.kpi_id) {
                    data.push(obj);
                }
            }

            return data;
        }

        // Update negative indicators on filter buttons
        function updateNegativeIndicators() {
            const sections = {};
            
            // Group KPIs by section and count negatives
            kpiData.forEach(kpi => {
                const section = kpi.section || 'Uncategorized';
                if (!sections[section]) {
                    sections[section] = { total: 0, negative: 0 };
                }
                sections[section].total++;
                
                if (kpi.trend_direction === 'down') {
                    sections[section].negative++;
                }
            });

            // Update badges
            const sectionNames = ['Quote', 'Onboarding', 'Billing', 'Services', 'Claims', 'Transactional'];
            
            // Calculate total negatives for "All Sections"
            let totalNegatives = 0;
            sectionNames.forEach(section => {
                const badge = document.getElementById(`badge-${section}`);
                const negCount = sections[section]?.negative || 0;
                totalNegatives += negCount;
                
                if (negCount > 0) {
                    badge.innerHTML = `⚠️ ${negCount}`;
                    badge.style.display = 'inline-flex';
                } else {
                    badge.style.display = 'none';
                }
            });

            // Update "All Sections" badge
            const allBadge = document.getElementById('badge-all');
            if (totalNegatives > 0) {
                allBadge.innerHTML = `⚠️ ${totalNegatives}`;
                allBadge.style.display = 'inline-flex';
            } else {
                allBadge.style.display = 'none';
            }
        }

        // Render dashboard dynamically
        function renderDashboard() {
            const dashboardContent = document.getElementById('dashboardContent');
            dashboardContent.innerHTML = '';

            // Group KPIs by section
            const sections = {};
            kpiData.forEach(kpi => {
                const section = kpi.section || 'Uncategorized';
                if (!sections[section]) {
                    sections[section] = [];
                }
                sections[section].push(kpi);
            });

            // Create sections with 2-column layout
            Object.keys(sections).sort().forEach(sectionName => {
                const sectionDiv = document.createElement('div');
                sectionDiv.className = `section active section-${sectionName.toLowerCase().replace(/\s+/g, '-')}`;
                sectionDiv.dataset.section = sectionName;

                const headerDiv = document.createElement('div');
                headerDiv.className = 'section-header';

                const iconMap = {
                    'Quote': '📋',
                    'Onboarding': '🚀',
                    'Billing': '💳',
                    'Services': '🔧',
                    'Claims': '📋',
                    'Transactional': '📊'
                };

                headerDiv.textContent = `${iconMap[sectionName] || '📊'} ${sectionName}`;
                sectionDiv.appendChild(headerDiv);

                const gridDiv = document.createElement('div');
                gridDiv.className = 'kpi-grid';

                sections[sectionName].forEach(kpi => {
                    const card = createKPICard(kpi);
                    gridDiv.appendChild(card);
                });

                sectionDiv.appendChild(gridDiv);
                dashboardContent.appendChild(sectionDiv);
            });

            // Render all trend charts
            setTimeout(() => {
                renderAllTrendCharts();
            }, 100);
        }

        // Create KPI card element
        function createKPICard(kpi) {
            const card = document.createElement('div');
            card.className = 'kpi-card';
            card.dataset.kpiId = kpi.kpi_id;

            const currentValue = parseFloat(kpi.current_value) || 0;
            const changePercentage = parseFloat(kpi.change_percentage) || 0;
            const trendDirection = kpi.trend_direction || 'same';

            const changeClass = changePercentage > 0 ? 'change-positive' : changePercentage < 0 ? 'change-negative' : 'change-neutral';
            const indicatorClass = trendDirection === 'up' ? 'indicator-up' : trendDirection === 'down' ? 'indicator-down' : 'indicator-same';
            const indicatorSymbol = trendDirection === 'up' ? '↑' : trendDirection === 'down' ? '↓' : '→';
            const changeSymbol = changePercentage > 0 ? '+' : '';

            card.innerHTML = `
                <div class="kpi-label">${kpi.kpi_name}</div>
                <div class="kpi-value">
                    <span>${currentValue}</span>
                    <span class="kpi-unit">${kpi.unit}</span>
                </div>
                <div class="kpi-change">
                    <span class="change-value ${changeClass}">${changeSymbol}${changePercentage}${kpi.unit === 'count' ? '' : '%'}</span>
                    <span class="indicator ${indicatorClass}">${indicatorSymbol}</span>
                </div>
                <div class="trend-container">
                    <canvas id="trend-${kpi.kpi_id}" class="trend-canvas"></canvas>
                </div>
                <div class="kpi-footer">vs previous period</div>
            `;

            return card;
        }

        // Render all trend charts
        function renderAllTrendCharts() {
            kpiData.forEach(kpi => {
                const canvasId = `trend-${kpi.kpi_id}`;
                const canvas = document.getElementById(canvasId);

                if (!canvas) return;

                // Extract 24-month data
                const trendData = [];
                for (let i = 1; i <= 24; i++) {
                    const monthKey = `month_${i}`;
                    const value = parseFloat(kpi[monthKey]) || 0;
                    trendData.push(value);
                }

                // Destroy existing chart if it exists
                if (chartInstances[canvasId]) {
                    chartInstances[canvasId].destroy();
                }

                // Determine color based on trend
                let borderColor = '#fdb913';
                let backgroundColor = 'rgba(253, 185, 19, 0.1)';

                if (kpi.trend_direction === 'down') {
                    borderColor = '#dc3545';
                    backgroundColor = 'rgba(220, 53, 69, 0.1)';
                } else if (kpi.trend_direction === 'up') {
                    borderColor = '#28a745';
                    backgroundColor = 'rgba(40, 167, 69, 0.1)';
                }

                const chartData = {
                    labels: Array.from({ length: 24 }, (_, i) => `M${i + 1}`),
                    datasets: [{
                        data: trendData,
                        borderColor: borderColor,
                        backgroundColor: backgroundColor,
                        borderWidth: 2,
                        fill: true,
                        pointRadius: 0,
                        pointHoverRadius: 0,
                        tension: 0.4
                    }]
                };

                chartInstances[canvasId] = new Chart(canvas, {
                    type: 'line',
                    data: chartData,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: { enabled: false }
                        },
                        scales: {
                            x: { display: false },
                            y: { display: false }
                        }
                    }
                });
            });
        }

        // Filter sections
        function filterSection(event, section) {
            if (event) {
                event.preventDefault();
            }
            
            currentFilter = section;

            // Update filter button states
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            if (event) {
                event.target.closest('.filter-btn').classList.add('active');
            } else {
                document.querySelectorAll('.filter-btn')[0].classList.add('active');
            }

            // Show/hide sections
            document.querySelectorAll('.section').forEach(sec => {
                if (section === 'all' || sec.dataset.section === section) {
                    sec.classList.add('active');
                } else {
                    sec.classList.remove('active');
                }
            });
        }

        // Show error message
        function showError(message) {
            const errorDiv = document.getElementById('errorMessage');
            errorDiv.textContent = message;
            errorDiv.style.display = 'block';
            setTimeout(() => {
                errorDiv.style.display = 'none';
            }, 6000);
        }

        // Show success message
        function showSuccess(message) {
            const successDiv = document.getElementById('successMessage');
            successDiv.textContent = message;
            successDiv.style.display = 'block';
            setTimeout(() => {
                successDiv.style.display = 'none';
            }, 6000);
        }

        // Load local CSV on page load
        window.addEventListener('load', () => {
            loadLocalCSV();
        });
    </script>
</body>
</html>
